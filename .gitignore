.env
.env.*
!.env.example

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

tmp/

# Local snapshots written by `npm run push` for `npm run rollback` recovery.
# Operator-local; not shared.
.vapi-state.*.snapshots/

# Local agent state
.claude/
.agent/
.agent/handoffs/
.claude/handoffs/
