# Dependencies
node_modules/
# This repo uses npm (package-lock.json). Stray pnpm-lock.yaml files
# can appear if someone accidentally runs `pnpm install` — never commit them.
pnpm-lock.yaml

# Environment files (secrets - never commit these!)
# Covers dev/stg/prod and any org slug (e.g. .env.roofr-production)
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

tmp/

# Local snapshots written by `npm run push` for `npm run rollback` recovery.
# Operator-local; not shared.
.vapi-state.*.snapshots/

# Per-developer drift baseline store (.vapi-state-hash/<org>/<uuid>).
# Holds "the last platform state I saw" per resource. Local, not shared —
# committing it would make one developer's baseline everyone's.
.vapi-state-hash/

# Local agent state
.claude/
.agent/
.agent/handoffs/
.claude/handoffs/

# Local scratch notes
requested improvements.md
